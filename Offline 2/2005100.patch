+// user/load.c
+
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/fcntl.h"
+
+int main(int argc, char *argv[])
+{
+    if (argc != 3)
+    {
+        printf("Usage: load childCount allocationAmount\n");
+        exit(1);
+    }
+
+    int childCount = atoi(argv[1]);
+    int allocationAmount = atoi(argv[2]);
+
+    if (childCount < 0 || allocationAmount < 0)
+    {
+        printf("Invalid arguments\n");
+        exit(1);
+    }
+
+    printf("Parent going to sleep.\n");
+
+    for (int i = 0; i < childCount; i++)
+    {
+        sleep(30);
+        int pid = fork();
+        sleep(5);
+        if (pid < 0)
+        {
+            printf("Fork failed\n");
+            exit(1);
+        }
+        if (pid == 0)
+        {
+            // Child process
+            printf("Child is created.\n");
+            char *mem = malloc(allocationAmount);
+            if (mem == 0)
+            {
+                printf("malloc failed\n");
+                exit(1);
+            }
+            printf("Child allocated %d byte.\n", allocationAmount);
+            printf("Child going to sleep.\n");
+            sleep(5); // Sleep for a large amount of time
+            free(mem);
+            exit(0);
+        }
+    }
+
+    // Parent process sleeps to allow children to allocate memory
+    sleep(20);
+
+    // Call the info system call
+    struct procInfo pInfo;
+    if (info(&pInfo) < 0)
+    {
+        printf("info syscall failed\n");
+        exit(1);
+    }
+
+    printf("Parent wake up.\n");
+    printf("Current system information:\n");
+    printf("Processes: %d/%d\n", pInfo.activeProcess, pInfo.totalProcess);
+    printf("RAM: %d/%d (in bytes)\n", pInfo.memsize, pInfo.totalMemSize);
+
+    exit(0);
+}
