diff --git a/user/trace.c b/user/trace.c
new file mode 100644
index 0000000..8087988
--- /dev/null
+++ b/user/trace.c
@@ -0,0 +1,41 @@
+// user/trace.c
+
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[])
+{
+    if (argc < 3)
+    {
+        printf("Usage: trace syscall_num command [args...]\n");
+        exit(1);
+    }
+
+    int syscall_num = atoi(argv[1]);
+    if (syscall_num < 0 || syscall_num >= 23)
+    {
+        printf("Invalid syscall number\n");
+        exit(1);
+    }
+
+    int pid = fork();
+
+    if (pid < 0)
+    {
+        printf("fork failed\n");
+        exit(1);
+    }
+
+    if (pid == 0)
+    {
+        trace(syscall_num);
+        exec(argv[2], argv + 2);
+        printf("exec failed\n");
+        exit(1);
+    }
+
+    int status;
+    wait(&status);
+    exit(0);
+}
