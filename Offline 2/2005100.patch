+// };
+
+// struct spinlock ptable_lock;
+// extern struct proc proc[NPROC];
+extern struct proc proc[NPROC];
+
+uint64
+sys_info(void)
+{
+  struct procInfo pInfo;
+  struct proc *p;
+  int active = 0;
+  int total = 0;
+  int mem = 0;
+
+  // Acquire the process table lock to safely iterate over processes;
+  // acquire(&proc->lock);
+  for (p = proc; p < &proc[NPROC]; p++)
+  {
+    acquire(&p->lock);
+    if (p->state == RUNNABLE || p->state == RUNNING || p->state == SLEEPING)
+    {
+      active++;
+      mem += p->sz;
+    }
+    // if (p->state != UNUSED)
+    // {
+    //   total++;
+    //   mem += p->sz; // Assuming sz is in bytes
+    // }
+    release(&p->lock);
+  }
+  // release(&proc->lock);
+
+  // Calculate total physical memory in bytes
+  // PHYSTOP is defined in memlayout.h as the top of physical memory
+  uint totalMem = PHYSTOP - KERNBASE;
+  total = NPROC;
+  // Populate the procInfo structure
+  pInfo.activeProcess = active;
+  pInfo.totalProcess = total;
+  pInfo.memsize = mem;
+  pInfo.totalMemSize = totalMem;
+
+  uint64 user_pInfo; // User-space pointer to procInfo
+
+  argaddr(0, &user_pInfo); // Fetch the user-space pointer to procInfo
+  printf("%d %d %d %d\n", pInfo.activeProcess, pInfo.totalProcess, pInfo.memsize, pInfo.totalMemSize);
+  // Copy the procInfo structure to user space
+  if (copyout(myproc()->pagetable, user_pInfo, (char *)&pInfo, sizeof(pInfo)) < 0)
+  {
+    return -1;
+  }
+
+  return 0;
+}
+
+uint64
+sys_sethistory(void)
+{
+  char cmd[128];
+  argstr(0, cmd, 128);
+  // printf("cmd: %s\n", cmd);
+  struct proc *p = myproc();
+  acquire(&p->cmd_lock);
+  if (p->history_count == 10)
+  {
+    safestrcpy(p->history[p->history_start], cmd, 128);
+    p->history_start = (p->history_start + 1) % 10;
+  }
+  else
+  {
+    safestrcpy(p->history[p->history_count], cmd, 128);
+    p->history_count++;
+  }
+  release(&p->cmd_lock);
+  // printf("history count: %d\n", p->history_count);
+  // printf("history : %s\n", p->history[p->history_count - 1]);
+  return 0;
+}
+
+uint64
+sys_gethistory(void)
+{
+  char *buf;
+  int n;
+
+  // Retrieve arguments: pointer to buffer and the command index
+  argaddr(0, (uint64 *)&buf);
+  argint(1, &n);
+
+  struct proc *p = myproc();
+
+  // Validate n
+  if (n <= 0 || n > 10)
+    return -1;
+
+  if (n > p->history_count)
+  {
+    // Not enough history
+    return -1;
+  }
+
+  // Calculate the index of the desired command
+  int index = (p->history_start + p->history_count - n) % 10;
+
+  // Copy the command to a temporary buffer
+  char temp[128];
+  safestrcpy(temp, p->history[index], 128);
+  // strncpy(temp, p->history[index], 127);
+  // temp[MAXCMD - 1] = '\0'; // Ensure null-termination
+
+  // Copy the command to user space buffer
+  if (copyout(p->pagetable, (uint64)buf, temp, strlen(temp)) < 0)
+    return -1;
+
+  return strlen(temp);
+}
