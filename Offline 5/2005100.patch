diff --git a/user/thread_locks.c b/user/thread_locks.c
new file mode 100644
index 0000000..9d57f29
--- /dev/null
+++ b/user/thread_locks.c
@@ -0,0 +1,38 @@
+#include "thread_locks.h"
+#include "user/user.h"
+// Spinlock initialization
+void thread_spin_init(thread_spinlock *lk) {
+    lk->locked = 0;
+}
+
+// Mutex initialization
+void thread_mutex_init(thread_mutex *lk) {
+    lk->locked = 0;
+}
+
+// Spinlock lock
+void thread_spin_lock(thread_spinlock *lk) {
+    while (__sync_lock_test_and_set(&lk->locked, 1) != 0)
+        ; // Busy wait
+    __sync_synchronize();
+}
+
+// Mutex lock (with sleep)
+void thread_mutex_lock(thread_mutex *lk) {
+    while (__sync_lock_test_and_set(&lk->locked, 1) != 0) {
+        sleep(1);
+    }
+    __sync_synchronize();
+}
+
+// Spinlock unlock
+void thread_spin_unlock(thread_spinlock *lk) {
+    __sync_synchronize();
+    __sync_lock_release(&lk->locked);
+}
+
+// Mutex unlock
+void thread_mutex_unlock(thread_mutex *lk) {
+    __sync_synchronize();
+    __sync_lock_release(&lk->locked);
+}
